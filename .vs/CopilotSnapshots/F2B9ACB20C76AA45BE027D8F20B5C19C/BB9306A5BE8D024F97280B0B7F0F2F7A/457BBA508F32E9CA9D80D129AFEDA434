using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.AI;
using Microsoft.SemanticKernel;
using Microsoft.SemanticKernel.Text;
using New.AI.Chat.Data;
using New.AI.Chat.DTOs;
using New.AI.Chat.Extensions;
using New.AI.Chat.Models;
using New.AI.Chat.Services.Interfaces;
using Pgvector;
using System.Text;

namespace New.AI.Chat.Services
{
    public class IngestionService : DefaultService<IngestionDTO, IngestionResponseDTO>, IIngestionService
    {
        private readonly ILogger<IngestionService> _logger;
        private readonly Kernel _kernel;
        private readonly AIDbContext _aiDbContext;

        public IngestionService(ILogger<IngestionService> logger,
            AIDbContext aiDbContext,
            Kernel kernel)
        {
            _logger = logger;
            _aiDbContext = aiDbContext;
            _kernel = kernel;
        }

        protected override async Task Validate(IngestionDTO ingestionFile)
        {
            if (ingestionFile?.IngestionFiles == null || !ingestionFile.IngestionFiles.Any())
            {
                AddError("A lista de arquivos está vazia ou nula!");
            }
            else
            {
                foreach (var file in ingestionFile.IngestionFiles)
                {
                    if (file is null)
                    {
                        AddError("Arquivo vazio!");
                    }
                    else
                    {
                        if (string.IsNullOrEmpty(file.FileName))
                        {
                            AddError("O nome do arquivo é obrigatório.");
                        }

                        if (string.IsNullOrEmpty(file.ContentText))
                        {
                            AddError($"O conteúdo do arquivo {file.FileName} está vazio!");
                        }
                        else if (!file.ContentText.IsBase64String())
                        {
                            AddError($"Formato inválido no arquivo {file.FileName}. O tipo esperado é um base64.");
                        }
                    }                    
                }
            }            
        }

        protected override async Task DoProcess(IngestionDTO ingestionFile)
        {
            int interador = 0;

            var generatorVectors = _kernel.GetRequiredService<IEmbeddingGenerator<string, Embedding<float>>>();

            foreach (var file in ingestionFile.IngestionFiles)
            {
                try
                {
                    interador++;

                    _logger.LogInformation($"{DateTime.Now.ToString("dd/MM/yyyy hh:mm:ss")} - Arquivo {file.FileName}: {interador} de {ingestionFile.IngestionFiles.Count()}");

                    var fileExists = await _aiDbContext.DbSetKDInformation.AnyAsync(f => f.FileName == file.FileName);

                    if (!fileExists)
                    {
                        var kdInformation = new KnowledgeDocumentInformation
                        {
                            FileName = file.FileName,
                            Format = file.Format,
                            Size = file.Size,
                            DateFirstInsertion = DateTime.Now,
                            DateLastInsertion = DateTime.Now,
                            LowGranularityList,
                            HighGranularityList,
                        };


                        var originalFileInBytes = Convert.FromBase64String(file.ContentText);
                        var originalFile = Encoding.UTF8.GetString(originalFileInBytes);

                        async List<KnowledgeDocumentHighGranularity> GetKnowledgeDocumentHighGranularity(IEmbeddingGenerator<string, Embedding<float>> generatorVectors, string originalFile)
                        {
                            // Fatiamento em baixa granularidade (Bloco Pai: ~800 tokens):
                            var parentLines = TextChunker.SplitPlainTextLines(originalFile, maxTokensPerLine: 120);
                            var parentChunks = TextChunker.SplitPlainTextParagraphs(parentLines, maxTokensPerParagraph: 800, overlapTokens: 100);

                            // Geração de vetores para baixas granularidades:
                            var parentVectors = await generatorVectors.GenerateAsync(parentChunks);

                            var vetoresAndChunks = parentVectors.Zip(parentChunks, (vector, chunk) => new { Vector = vector, Chunk = chunk }).ToList();

                            foreach (var (vector, chunk) in vetoresAndChunks)
                            {

                            }

                            var documentosPaiParaInserir = new List<KnowledgeDocumentParent>(parentChunks.Count);

                            for (int i = 0; i < parentChunks.Count; i++)
                            {
                                var parentEntity = new KnowledgeDocumentParent
                                {
                                    Font = file.FileName,
                                    ContentText = parentChunks[i],
                                    Embedding = new Vector(parentVectors[i].Vector.ToArray())
                                };

                                // 2. FATIAMENTO FILHO (Lente de Aumento: ~150 tokens)
                                var childLines = TextChunker.SplitPlainTextLines(parentChunks[i], maxTokensPerLine: 60);
                                var childChunks = TextChunker.SplitPlainTextParagraphs(childLines, maxTokensPerParagraph: 150, overlapTokens: 30);

                                // Geração de vetores em lote para os blocos Filho
                                var childVectors = await generatorVectors.GenerateAsync(childChunks);

                                for (int j = 0; j < childChunks.Count; j++)
                                {
                                    parentEntity.Children.Add(new KnowledgeDocumentChild
                                    {
                                        ContentText = childChunks[j],
                                        Embedding = new Vector(childVectors[j].Vector.ToArray())
                                    });
                                }

                                documentosPaiParaInserir.Add(parentEntity);
                            }
                        }

                        

                        // Inserção em massa: O EF Core gerencia os IDs e os relacionamentos ParentId automaticamente
                        await _aiDbContext.KnowledgeDocumentParents.AddRangeAsync(documentosPaiParaInserir);
                        await _aiDbContext.SaveChangesAsync();
                    }
                    else
                    {
                        _logger.LogWarning("{Data} - Arquivo {FileName} já existe na base de dados.",
                            DateTime.Now.ToString("dd/MM/yyyy hh:mm:ss"), file.FileName);
                    }
                }
                catch (Exception ex)
                {
                    AddError($"{DateTime.Now.ToString("dd/MM/yyyy hh:mm:ss")} - Erro ao processar o arquivo {file.FileName}: {ex.Message} | {ex?.InnerException?.Message}");
                }
            }
        }
    }
}
